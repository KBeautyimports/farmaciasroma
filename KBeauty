  "Peptides":"Peptidos","Centella/Cica":"Centella Asiatica","Panthenol (B5)":"Pantenol B5",
  "Azelaic Acid":"Ac. Azelaico","Squalane":"Escualano","Snail Mucin":"Mucina Caracol",
  "Probiotics":"Probioticos","Tranexamic Acid":"Ac. Tranexamico","Sunscreen":"SPF"
};
var SKIN_LABELS = {
  "Dry_Skin":"Seca","Oily_Skin":"Grasa","Combination_Skin":"Mixta",
  "Sensitive_Skin":"Sensible","Mature_Skin":"Madura"
};

var selectedSkinType = null;
var selectedConcernActives = new Set();
var filteredProducts = [];

// Wire up skin type buttons
document.querySelectorAll('.skin-btn').forEach(function(btn) {
  btn.addEventListener('click', function() { selectSkinType(btn); });
});

// Wire up concern buttons
document.querySelectorAll('.concern-btn').forEach(function(btn) {
  btn.addEventListener('click', function() { toggleConcern(btn); });
});

// Wire up other buttons
document.getElementById('showResultsBtn').addEventListener('click', showResults);
document.getElementById('backBtn').addEventListener('click', goBack);
document.getElementById('modalCloseBtn').addEventListener('click', closeModal);
document.getElementById('modalOverlay').addEventListener('click', function(e) {
  if (e.target === document.getElementById('modalOverlay')) closeModal();
});

function selectSkinType(btn) {
  document.querySelectorAll('.skin-btn').forEach(function(b) { b.classList.remove('selected'); });
  btn.classList.add('selected');
  selectedSkinType = btn.dataset.type;
  setTimeout(function() {
    document.getElementById('stage1').classList.remove('visible');
    document.getElementById('dot1').classList.remove('active');
    document.getElementById('dot1').classList.add('done');
    document.getElementById('stage2').classList.add('visible');
    document.getElementById('dot2').classList.add('active');
  }, 350);
}

function toggleConcern(btn) {
  btn.classList.toggle('selected');
  var actives = btn.dataset.actives.split(',').map(function(s) { return s.trim(); });
  if (btn.classList.contains('selected')) {
    actives.forEach(function(a) { selectedConcernActives.add(a); });
  } else {
    actives.forEach(function(a) {
      var stillNeeded = false;
      document.querySelectorAll('.concern-btn.selected').forEach(function(b) {
        if (b.dataset.actives.split(',').map(function(s){return s.trim();}).indexOf(a) !== -1) stillNeeded = true;
      });
      if (!stillNeeded) selectedConcernActives.delete(a);
    });
  }
  document.getElementById('showResultsBtn').disabled = selectedConcernActives.size === 0;
}

function showResults() {
  document.getElementById('stage2').classList.remove('visible');
  document.getElementById('dot2').classList.remove('active');
  document.getElementById('dot2').classList.add('done');
  document.getElementById('stage3').classList.add('visible');
  document.getElementById('dot3').classList.add('active');
  renderResults();
}

function renderResults() {
  activeTypeFilter = 'all';
  activeIngFilter = 'all';

  filteredProducts = PRODUCTS.filter(function(p) {
    var skinOk = !selectedSkinType || p[selectedSkinType] === 'Yes' || p['Skin_Type_Summary'] === 'All/General';
    if (!skinOk) return false;
    if (selectedConcernActives.size === 0) return true;
    var matched = false;
    selectedConcernActives.forEach(function(active) { if (p[active] === 'Yes') matched = true; });
    return matched;
  });

  filteredProducts.sort(function(a, b) {
    var sa = 0, sb = 0;
    selectedConcernActives.forEach(function(ac) { if (a[ac] === 'Yes') sa++; if (b[ac] === 'Yes') sb++; });
    return sb - sa;
  });

  var meta = document.getElementById('resultsMeta');
  var skinName = SKIN_LABELS[selectedSkinType] || '';
  meta.innerHTML = skinName ? '<span class="meta-tag">Piel ' + skinName + '</span>' : '';
  document.querySelectorAll('.concern-btn.selected').forEach(function(btn) {
    meta.innerHTML += '<span class="meta-tag">' + btn.querySelector('.concern-btn-name').textContent + '</span>';
  });

  // Build type filter bar
  var presentTypes = {};
  filteredProducts.forEach(function(p) {
    var t = getProductType(p.Producto);
    presentTypes[t] = (presentTypes[t] || 0) + 1;
  });

  var typeBar = document.getElementById('typeFilterBar');
  typeBar.innerHTML = '';
  var typeAllChip = document.createElement('button');
  typeAllChip.className = 'type-chip active';
  typeAllChip.textContent = 'Todos los tipos';
  typeAllChip.addEventListener('click', function() { applyTypeFilter(typeAllChip, 'all'); });
  typeBar.appendChild(typeAllChip);
  Object.keys(presentTypes).sort().forEach(function(type) {
    var chip = document.createElement('button');
    chip.className = 'type-chip';
    chip.textContent = type + ' (' + presentTypes[type] + ')';
    chip.addEventListener('click', (function(t, c){ return function() { applyTypeFilter(c, t); }; })(type, chip));
    typeBar.appendChild(chip);
  });

  // Build actives filter bar
  var presentActives = {};
  filteredProducts.forEach(function(p) {
    Object.keys(ACTIVE_LABELS).forEach(function(key) { if (p[key] === 'Yes') presentActives[key] = true; });
  });

  var filterBar = document.getElementById('filterBar');
  filterBar.innerHTML = '';
  var allChip = document.createElement('button');
  allChip.className = 'filter-chip active';
  allChip.textContent = 'Todos los activos';
  allChip.addEventListener('click', function() { applyIngFilter(allChip, 'all'); });
  filterBar.appendChild(allChip);
  Object.keys(presentActives).forEach(function(key) {
    var chip = document.createElement('button');
    chip.className = 'filter-chip';
    chip.textContent = ACTIVE_LABELS[key];
    chip.addEventListener('click', (function(k, c){ return function() { applyIngFilter(c, k); }; })(key, chip));
    filterBar.appendChild(chip);
  });

  var divider = document.getElementById('filterDivider');
  if (divider) divider.style.display = Object.keys(presentActives).length > 0 ? '' : 'none';

  renderProductCards(filteredProducts);
  updateVisibleCards();
  updateCount();
}

function getVisibleProducts() {
  return filteredProducts.filter(function(p) {
    var typeOk = activeTypeFilter === 'all' || getProductType(p.Producto) === activeTypeFilter;
    var ingOk  = activeIngFilter  === 'all' || p[activeIngFilter] === 'Yes';
    return typeOk && ingOk;
  });
}

function updateVisibleCards() {
  var visible = {};
  getVisibleProducts().forEach(function(p) { visible[p.Producto] = true; });
  document.querySelectorAll('.product-card').forEach(function(card) {
    card.classList.toggle('hidden', !visible[card.dataset.product]);
  });
}

function updateCount() {
  document.getElementById('countLabel').textContent = getVisibleProducts().length + ' productos encontrados';
}

function applyTypeFilter(btn, type) {
  activeTypeFilter = type;
  document.querySelectorAll('.type-chip').forEach(function(c) { c.classList.remove('active'); });
  btn.classList.add('active');
  updateVisibleCards();
  updateCount();
}

function applyIngFilter(btn, filter) {
  activeIngFilter = filter;
  document.querySelectorAll('.filter-chip').forEach(function(c) { c.classList.remove('active'); });
  btn.classList.add('active');
  updateVisibleCards();
  updateCount();
}

function renderProductCards(products) {
  var grid = document.getElementById('productsGrid');
  grid.innerHTML = '';
  if (products.length === 0) {
    grid.innerHTML = '<div class="no-results"><p>No encontramos productos. Prueba ajustando tu seleccion.</p></div>';
    return;
  }
  products.forEach(function(p, i) {
    var actives = p.Detected_Actives_Summary ? p.Detected_Actives_Summary.split(',').map(function(s){return s.trim();}).filter(Boolean) : [];
    var skinTypes = Object.keys(SKIN_LABELS).filter(function(k){ return p[k] === 'Yes'; }).map(function(k){ return SKIN_LABELS[k]; });
    var activeTags = actives.map(function(a) {
      var isMatch = selectedConcernActives.has(a);
      return '<span class="active-tag' + (isMatch ? ' highlight' : '') + '">' + (ACTIVE_LABELS[a] || a) + '</span>';
    }).join('');
    var skinPills = skinTypes.map(function(s){ return '<span class="skin-pill">' + s + '</span>'; }).join('');
    var descLines = p.Descripcion ? p.Descripcion.split('\n').map(function(l){return l.trim();}).filter(Boolean) : [];
    // Skip generic header lines like "Qué es:" / "Qué es: "
    var descShort = '';
    for (var di = 0; di < descLines.length; di++) {
      var line = descLines[di];
      if (/^qu[eé]\s*es\s*:?\s*$/i.test(line)) continue;
      descShort = line; break;
    }

    var card = document.createElement('div');
    card.className = 'product-card';
    card.dataset.product = p.Producto;
    card.style.animationDelay = (i * 0.05) + 's';

    var imgHtml = p.Image_url
      ? '<span class="product-img-placeholder" style="position:absolute;opacity:.15">&#129516;</span><img src="' + p.Image_url + '" alt="" loading="lazy" style="position:relative">'
      : '<span class="product-img-placeholder">&#129516;</span>';

    card.innerHTML =
      '<div class="product-img-wrap">' + imgHtml + '</div>' +
      '<div class="product-body">' +
        '<div class="product-brand">' + p.Marca + '</div>' +
        '<div class="product-name">' + p.Producto + '</div>' +
        '<div class="product-actives">' + activeTags + '</div>' +
        '<p class="product-desc">' + descShort + '</p>' +
      '</div>' +
      '<div class="product-footer">' +
        '<div class="skin-types-pills">' + skinPills + '</div>' +
        '<button class="expand-btn">Ver mas</button>' +
      '</div>';

    // Handle broken images - hide the img, placeholder behind it stays visible
    var img = card.querySelector('img');
    if (img) {
      img.addEventListener('error', function() {
        this.style.display = 'none';
        var ph = this.previousElementSibling;
        if (ph) ph.style.opacity = '0.35';
      });
    }

    card.querySelector('.expand-btn').addEventListener('click', (function(prod){ return function() { openModal(prod); }; })(p));
    grid.appendChild(card);
  });
}

function openModal(p) {
  var actives = p.Detected_Actives_Summary ? p.Detected_Actives_Summary.split(',').map(function(s){return s.trim();}).filter(Boolean) : [];
  var imgEl = document.getElementById('modalImg');
  if (p.Image_url) {
    imgEl.src = p.Image_url;
    imgEl.style.display = '';
    imgEl.onerror = function() { this.style.display = 'none'; };
  } else {
    imgEl.style.display = 'none';
  }
  document.getElementById('modalBrand').textContent = p.Marca;
  document.getElementById('modalTitle').textContent = p.Producto;
  document.getElementById('modalDesc').textContent = p.Descripcion || '';
  document.getElementById('modalIngredients').textContent = p.Ingredientes || '';
  var activesEl = document.getElementById('modalActives');
  activesEl.innerHTML = actives.map(function(a) {
    var isMatch = selectedConcernActives.has(a);
    return '<span class="active-tag' + (isMatch ? ' highlight' : '') + '">' + (ACTIVE_LABELS[a] || a) + '</span>';
  }).join('');
  document.getElementById('modalOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal() {
  document.getElementById('modalOverlay').classList.remove('open');
  document.body.style.overflow = '';
}

function goBack() {
  document.getElementById('stage3').classList.remove('visible');
  document.getElementById('dot3').classList.remove('active');
  document.getElementById('dot2').classList.remove('done');
  document.getElementById('dot1').classList.remove('done');
  activeTypeFilter = 'all';
  activeIngFilter = 'all';
  selectedSkinType = null;
  selectedConcernActives = new Set();
  document.querySelectorAll('.skin-btn').forEach(function(b) { b.classList.remove('selected'); });
  document.querySelectorAll('.concern-btn').forEach(function(b) { b.classList.remove('selected'); });
  document.getElementById('showResultsBtn').disabled = true;
  document.getElementById('stage1').classList.add('visible');
  document.getElementById('dot1').classList.add('active');
}
</script>
