<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ritual de Piel — Diagnóstico</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{--cream:#F7F3EE;--warm-white:#FDFAF7;--blush:#E8D5C8;--rose:#C4957A;--deep-rose:#A0725A;--sage:#8A9E8C;--dark:#2C2420;--mid:#6B5448;--light-border:#E2D5CC;--shadow:rgba(44,36,32,0.08)}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--dark);min-height:100vh;overflow-x:hidden}
.app{position:relative;z-index:1}
header{padding:2.5rem 3rem 1.5rem;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--light-border)}
.logo{font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:300;letter-spacing:.15em;text-transform:uppercase;color:var(--dark)}
.logo span{color:var(--rose);font-style:italic}
.progress-bar{display:flex;gap:.5rem;align-items:center}
.progress-dot{width:8px;height:8px;border-radius:50%;background:var(--light-border);transition:all .4s ease}
.progress-dot.active{background:var(--rose);transform:scale(1.3)}
.progress-dot.done{background:var(--sage)}
.stage{display:none;min-height:calc(100vh - 80px);animation:fadeIn .6s ease forwards}
.stage.visible{display:flex}
@keyframes fadeIn{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
#stage1{flex-direction:column;align-items:center;justify-content:center;padding:4rem 2rem;text-align:center}
.stage-label{font-size:.7rem;letter-spacing:.25em;text-transform:uppercase;color:var(--rose);font-weight:500;margin-bottom:1rem}
.stage-title{font-family:'Cormorant Garamond',serif;font-size:clamp(2.5rem,5vw,4rem);font-weight:300;line-height:1.1;color:var(--dark);margin-bottom:.75rem}
.stage-title em{font-style:italic;color:var(--rose)}
.stage-subtitle{font-size:.95rem;color:var(--mid);font-weight:300;max-width:400px;margin:0 auto 3.5rem;line-height:1.6}
.skin-types-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:1.25rem;max-width:800px;width:100%}
.skin-btn{position:relative;background:var(--warm-white);border:1.5px solid var(--light-border);border-radius:2px;padding:2rem 1.5rem;cursor:pointer;transition:all .3s ease;text-align:center;overflow:hidden}
.skin-btn::before{content:'';position:absolute;inset:0;background:var(--blush);opacity:0;transition:opacity .3s ease}
.skin-btn:hover{border-color:var(--rose);transform:translateY(-3px);box-shadow:0 12px 30px var(--shadow)}
.skin-btn:hover::before{opacity:.3}
.skin-btn.selected{border-color:var(--rose);background:var(--blush);box-shadow:0 8px 24px var(--shadow)}
.skin-btn-icon{font-size:2rem;margin-bottom:.75rem;display:block;position:relative}
.skin-btn-name{font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:600;color:var(--dark);display:block;position:relative;margin-bottom:.4rem}
.skin-btn-desc{font-size:.75rem;color:var(--mid);position:relative;line-height:1.4}
#stage2{flex-direction:column;align-items:center;justify-content:center;padding:4rem 2rem;text-align:center}
.concerns-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:1rem;max-width:900px;width:100%;margin-bottom:2.5rem}
.concern-btn{position:relative;background:var(--warm-white);border:1.5px solid var(--light-border);border-radius:2px;padding:1.5rem 1.25rem;cursor:pointer;transition:all .3s ease;text-align:left;overflow:hidden}
.concern-btn:hover{border-color:var(--sage);transform:translateY(-2px);box-shadow:0 8px 20px var(--shadow)}
.concern-btn.selected{border-color:var(--sage);background:rgba(138,158,140,.12)}
.concern-check{position:absolute;top:.75rem;right:.75rem;width:20px;height:20px;border:1.5px solid var(--light-border);border-radius:50%;display:flex;align-items:center;justify-content:center;transition:all .3s;font-size:.65rem;color:white}
.concern-btn.selected .concern-check{background:var(--sage);border-color:var(--sage)}
.concern-btn-icon{font-size:1.5rem;margin-bottom:.5rem;display:block}
.concern-btn-name{font-family:'Cormorant Garamond',serif;font-size:1.05rem;font-weight:600;color:var(--dark);display:block;margin-bottom:.25rem}
.concern-btn-desc{font-size:.72rem;color:var(--mid);line-height:1.4}
.cta-btn{background:var(--dark);color:var(--cream);border:none;padding:1rem 3rem;font-family:'DM Sans',sans-serif;font-size:.8rem;letter-spacing:.2em;text-transform:uppercase;cursor:pointer;transition:all .3s ease;border-radius:1px}
.cta-btn:hover{background:var(--deep-rose);transform:translateY(-1px)}
.cta-btn:disabled{opacity:.4;cursor:not-allowed;transform:none}
#stage3{flex-direction:column;padding:3rem 2rem}
.results-header{text-align:center;margin-bottom:3rem;max-width:700px;margin-left:auto;margin-right:auto}
.results-meta{display:flex;gap:.75rem;justify-content:center;flex-wrap:wrap;margin-top:1.5rem}
.meta-tag{background:var(--blush);color:var(--mid);font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;padding:.4rem 1rem;border-radius:50px;font-weight:500}
.type-filter-bar{display:flex;gap:.6rem;flex-wrap:wrap;justify-content:center;margin-bottom:.75rem;padding:0 1rem}
.type-chip{background:var(--warm-white);border:1.5px solid var(--light-border);color:var(--mid);font-size:.72rem;padding:.45rem 1.1rem;border-radius:4px;cursor:pointer;transition:all .25s;font-family:'DM Sans',sans-serif;letter-spacing:.05em;font-weight:500}
.type-chip:hover{border-color:var(--deep-rose);color:var(--dark)}
.type-chip.active{background:var(--rose);border-color:var(--rose);color:white}
.filter-divider{text-align:center;font-size:.6rem;letter-spacing:.2em;text-transform:uppercase;color:var(--light-border);margin-bottom:.75rem}
.filter-bar{display:flex;gap:.75rem;flex-wrap:wrap;justify-content:center;margin-bottom:2.5rem;padding:0 1rem}
.filter-chip{background:var(--warm-white);border:1.5px solid var(--light-border);color:var(--mid);font-size:.75rem;padding:.5rem 1.2rem;border-radius:50px;cursor:pointer;transition:all .25s;font-family:'DM Sans',sans-serif;letter-spacing:.05em}
.filter-chip:hover{border-color:var(--rose);color:var(--dark)}
.filter-chip.active{background:var(--dark);border-color:var(--dark);color:white}
.products-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.5rem;max-width:1200px;margin:0 auto;width:100%}
.product-card{background:var(--warm-white);border:1px solid var(--light-border);border-radius:3px;overflow:hidden;transition:all .3s ease;animation:cardIn .5s ease forwards}
@keyframes cardIn{from{opacity:0;transform:translateY(15px)}to{opacity:1;transform:translateY(0)}}
.product-card:hover{transform:translateY(-4px);box-shadow:0 16px 40px var(--shadow);border-color:var(--rose)}
.product-card.hidden{display:none}
.product-img-wrap{aspect-ratio:1;overflow:hidden;background:var(--blush);display:flex;align-items:center;justify-content:center;position:relative}
.product-img-wrap img{position:absolute;inset:0;width:100%;height:100%;object-fit:contain;padding:1.5rem;transition:transform .4s ease}
.product-card:hover .product-img-wrap img{transform:scale(1.05)}
.product-img-placeholder{font-size:3rem;opacity:.3}
.product-body{padding:1.5rem}
.product-brand{font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;color:var(--rose);font-weight:500;margin-bottom:.3rem}
.product-name{font-family:'Cormorant Garamond',serif;font-size:1.15rem;font-weight:600;color:var(--dark);line-height:1.3;margin-bottom:.75rem}
.product-actives{display:flex;flex-wrap:wrap;gap:.35rem;margin-bottom:1rem}
.active-tag{font-size:.65rem;background:var(--blush);color:var(--mid);padding:.2rem .6rem;border-radius:50px;letter-spacing:.05em}
.active-tag.highlight{background:var(--sage);color:white}
.product-desc{font-size:.8rem;color:var(--mid);line-height:1.6;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
.product-footer{padding:1rem 1.5rem 1.5rem;display:flex;align-items:center;justify-content:space-between;border-top:1px solid var(--light-border);margin-top:.25rem}
.skin-types-pills{display:flex;flex-wrap:wrap;gap:.3rem}
.skin-pill{font-size:.6rem;border:1px solid var(--light-border);color:var(--mid);padding:.15rem .5rem;border-radius:50px;letter-spacing:.05em}
.expand-btn{background:none;border:1px solid var(--light-border);color:var(--mid);font-size:.7rem;padding:.35rem .8rem;border-radius:50px;cursor:pointer;transition:all .2s;font-family:'DM Sans',sans-serif;white-space:nowrap}
.expand-btn:hover{border-color:var(--dark);color:var(--dark)}
.modal-overlay{position:fixed;inset:0;background:rgba(44,36,32,.5);z-index:100;display:none;align-items:center;justify-content:center;padding:2rem;backdrop-filter:blur(4px)}
.modal-overlay.open{display:flex;animation:fadeIn .3s ease}
.modal{background:var(--warm-white);border-radius:3px;max-width:600px;width:100%;max-height:85vh;overflow-y:auto;animation:slideUp .4s ease}
@keyframes slideUp{from{transform:translateY(30px);opacity:0}to{transform:translateY(0);opacity:1}}
.modal-img{aspect-ratio:16/9;background:var(--blush);overflow:hidden;display:flex;align-items:center;justify-content:center}
.modal-img img{width:100%;height:100%;object-fit:contain;padding:2rem}
.modal-close-row{display:flex;justify-content:flex-end;padding:1rem 1rem 0}
.modal-close{background:var(--dark);color:white;border:none;width:36px;height:36px;border-radius:50%;font-size:1.2rem;cursor:pointer;display:flex;align-items:center;justify-content:center}
.modal-body{padding:1.5rem 2rem 2rem}
.modal-brand{font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;color:var(--rose);margin-bottom:.3rem}
.modal-title{font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-weight:400;margin-bottom:1.25rem}
.modal-section-title{font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;color:var(--mid);margin-bottom:.5rem;margin-top:1.25rem}
.modal-desc{font-size:.85rem;color:var(--dark);line-height:1.7;white-space:pre-line}
.modal-ingredients{font-size:.75rem;color:var(--mid);line-height:1.6}
.back-btn{background:none;border:1px solid var(--light-border);color:var(--mid);font-size:.75rem;padding:.5rem 1.2rem;cursor:pointer;font-family:'DM Sans',sans-serif;letter-spacing:.1em;text-transform:uppercase;transition:all .2s;margin-bottom:2rem;display:block}
.back-btn:hover{border-color:var(--dark);color:var(--dark)}
.count-label{text-align:center;font-size:.75rem;color:var(--mid);margin-bottom:1.5rem;letter-spacing:.05em}
.no-results{text-align:center;padding:4rem 2rem;grid-column:1/-1}
.no-results p{font-family:'Cormorant Garamond',serif;font-size:1.5rem;color:var(--mid)}
@media(max-width:640px){header{padding:1.5rem}.skin-types-grid{grid-template-columns:1fr 1fr}.concerns-grid{grid-template-columns:1fr 1fr}.products-grid{grid-template-columns:1fr}}
</style>
</head>
<body>
<div class="app">
  <header>
    <div class="logo"><img src="https://farmaciasroma.com/wp-content/uploads/2025/06/Logotipo-Farmacias-Roma-2025-1536x903.png" alt="Farmacias Roma" style="height:48px;width:auto;display:block;object-fit:contain"></div>
    <div class="progress-bar">
      <div class="progress-dot active" id="dot1"></div>
      <div class="progress-dot" id="dot2"></div>
      <div class="progress-dot" id="dot3"></div>
    </div>
  </header>
  <div class="stage visible" id="stage1">
    <div class="stage-label">Paso 01 de 03</div>
    <h1 class="stage-title">&#191;Cu&#225;l es tu<br><em>tipo de piel</em>?</h1>
    <p class="stage-subtitle">Selecciona la descripci&#243;n que mejor refleje c&#243;mo se comporta tu piel normalmente.</p>
    <div class="skin-types-grid">
      <button class="skin-btn" data-type="Dry_Skin"><span class="skin-btn-icon">&#127807;</span><span class="skin-btn-name">Seca</span><span class="skin-btn-desc">Se siente tirante, &#225;spera o descamada</span></button>
      <button class="skin-btn" data-type="Oily_Skin"><span class="skin-btn-icon">&#10024;</span><span class="skin-btn-name">Grasa</span><span class="skin-btn-desc">Brillo constante, poros dilatados</span></button>
      <button class="skin-btn" data-type="Combination_Skin"><span class="skin-btn-icon">&#9878;&#65039;</span><span class="skin-btn-name">Mixta</span><span class="skin-btn-desc">Zona T grasa, mejillas normales o secas</span></button>
      <button class="skin-btn" data-type="Sensitive_Skin"><span class="skin-btn-icon">&#127800;</span><span class="skin-btn-name">Sensible</span><span class="skin-btn-desc">Rojeces, reacciona f&#225;cilmente</span></button>
      <button class="skin-btn" data-type="Mature_Skin"><span class="skin-btn-icon">&#128538;</span><span class="skin-btn-name">Madura</span><span class="skin-btn-desc">L&#237;neas de expresi&#243;n, p&#233;rdida de firmeza</span></button>
    </div>
  </div>
  <div class="stage" id="stage2">
    <div class="stage-label">Paso 02 de 03</div>
    <h1 class="stage-title">&#191;Qu&#233; quieres<br><em>mejorar</em>?</h1>
    <p class="stage-subtitle">Puedes seleccionar varios objetivos. Te mostraremos los productos m&#225;s adecuados.</p>
    <div class="concerns-grid">
      <button class="concern-btn" data-actives="BHA (Salicylic),Niacinamide,Azelaic Acid"><span class="concern-check">&#10003;</span><span class="concern-btn-icon">&#128300;</span><span class="concern-btn-name">Acn&#233; &amp; Imperfecciones</span><span class="concern-btn-desc">Granos, puntos negros, poros</span></button>
      <button class="concern-btn" data-actives="Retinoids,Peptides,AHA (Glycolic/Lactic),PDRN (Salmon DNA)"><span class="concern-check">&#10003;</span><span class="concern-btn-icon">&#9203;</span><span class="concern-btn-name">Arrugas &amp; Firmeza</span><span class="concern-btn-desc">L&#237;neas finas, p&#233;rdida de elasticidad</span></button>
      <button class="concern-btn" data-actives="Vitamin C,Niacinamide,AHA (Glycolic/Lactic),Tranexamic Acid,Azelaic Acid"><span class="concern-check">&#10003;</span><span class="concern-btn-icon">&#127775;</span><span class="concern-btn-name">Manchas &amp; Uniformidad</span><span class="concern-btn-desc">Hiperpigmentaci&#243;n, tono desigual</span></button>
      <button class="concern-btn" data-actives="Hyaluronic Acid,Ceramides,Squalane,Panthenol (B5)"><span class="concern-check">&#10003;</span><span class="concern-btn-icon">&#128167;</span><span class="concern-btn-name">Hidrataci&#243;n Profunda</span><span class="concern-btn-desc">Piel tirante, deshidratada</span></button>
      <button class="concern-btn" data-actives="Centella/Cica,Ceramides,Panthenol (B5),Probiotics,Snail Mucin"><span class="concern-check">&#10003;</span><span class="concern-btn-icon">&#128737;&#65039;</span><span class="concern-btn-name">Calmar &amp; Reparar</span><span class="concern-btn-desc">Rojeces, irritaci&#243;n, barrera da&#241;ada</span></button>
      <button class="concern-btn" data-actives="Sunscreen"><span class="concern-check">&#10003;</span><span class="concern-btn-icon">&#9728;&#65039;</span><span class="concern-btn-name">Protecci&#243;n Solar</span><span class="concern-btn-desc">Prevenci&#243;n del da&#241;o solar</span></button>
      <button class="concern-btn" data-actives="Vitamin C,Niacinamide,Snail Mucin,Probiotics"><span class="concern-check">&#10003;</span><span class="concern-btn-icon">&#10024;</span><span class="concern-btn-name">Luminosidad</span><span class="concern-btn-desc">Piel apagada, sin brillo natural</span></button>
      <button class="concern-btn" data-actives="Ceramides,Squalane,Panthenol (B5),Centella/Cica"><span class="concern-check">&#10003;</span><span class="concern-btn-icon">&#127807;</span><span class="concern-btn-name">Barrera Cut&#225;nea</span><span class="concern-btn-desc">Piel reactiva, sensible al tacto</span></button>
    </div>
    <button class="cta-btn" id="showResultsBtn" disabled>Ver mis productos &#8594;</button>
  </div>
  <div class="stage" id="stage3">
    <div style="max-width:1200px;margin:0 auto;width:100%">
      <button class="back-btn" id="backBtn">&#8592; Volver al inicio</button>
      <div class="results-header">
        <div class="stage-label">Tu Selecci&#243;n Personalizada</div>
        <h1 class="stage-title" style="font-size:clamp(2rem,4vw,3rem)">Tus productos<br><em>ideales</em></h1>
        <div class="results-meta" id="resultsMeta"></div>
      </div>
      <div class="type-filter-bar" id="typeFilterBar"></div>
      <div class="filter-divider" id="filterDivider" style="display:none">&#9135;&#9135; activos &#9135;&#9135;</div>
      <div class="filter-bar" id="filterBar"></div>
      <div class="count-label" id="countLabel"></div>
      <div class="products-grid" id="productsGrid"></div>
    </div>
  </div>
</div>
<div class="modal-overlay" id="modalOverlay">
  <div class="modal" id="modalBox">
    <div class="modal-close-row"><button class="modal-close" id="modalCloseBtn">&#215;</button></div>
    <div class="modal-img"><img id="modalImg" src="" alt=""></div>
    <div class="modal-body">
      <div class="modal-brand" id="modalBrand"></div>
      <h2 class="modal-title" id="modalTitle"></h2>
      <div class="modal-section-title">Activos Clave</div>
      <div id="modalActives" style="display:flex;flex-wrap:wrap;gap:.4rem;margin-bottom:.5rem"></div>
      <div class="modal-section-title">Descripci&#243;n</div>
      <p class="modal-desc" id="modalDesc"></p>
      <div class="modal-section-title">Ingredientes</div>
      <p class="modal-ingredients" id="modalIngredients"></p>
    </div>
  </div>
</div>
