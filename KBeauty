};

function getProductType(name) {
  for (var type in PRODUCT_TYPES) {
    if (PRODUCT_TYPES[type].test(name)) return type;
  }
  return "Otro";
}

var activeTypeFilter = 'all';
var activeIngFilter = 'all';

var ACTIVE_LABELS = {
  "Niacinamide":"Niacinamida","Retinoids":"Retinol/Retinal","Vitamin C":"Vitamina C",
  "Hyaluronic Acid":"Ac. Hialuronico","PDRN (Salmon DNA)":"PDRN",
